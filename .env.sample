# MongoDB topology
RS_NAME=rs0
MONGO_DB_NAME=cinema_db

# Internal port — used inside the docker network, same for every replica node
MONGO_PORT=27017

# Hostnames (= container_name) — used by Spring as spring.mongodb.host
MONGO1_HOST=mongo1
MONGO2_HOST=mongo2
MONGO3_HOST=mongo3

# Host-side port mappings — what you use from your laptop (mongosh, Compass)
MONGO1_HOST_PORT=27017
MONGO2_HOST_PORT=27018
MONGO3_HOST_PORT=27019

# Application
APP_PORT=8080
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe!Secure123
# Generate with:  openssl rand -base64 96
JWT_SECRET_KEY=replace_me_with_openssl_rand_base64_96

# Mail (SMTP)
MAIL_USERNAME=
MAIL_PASSWORD=

# Redis (rate-limiter) — inside docker-compose the app connects to container "redis"
# REDIS_HOST and REDIS_PORT are injected directly in docker-compose.yml;
# override here only when running outside of docker-compose (e.g. local IDE run).
# REDIS_HOST=localhost
# REDIS_PORT=6379